# ============================================================
# Sentience AI — Ortam Değişkenleri Şablonu
# ============================================================
# Bu dosyayı `.env.local` olarak kopyalayın ve kendi değerlerinizi girin.
# cp .env.example .env.local

# Google AI Studio'dan ücretsiz anahtar alın: https://aistudio.google.com/apikey
# Birden fazla anahtar virgülle ayırarak ekleyin (otomatik rotasyon).
VITE_GEMINI_API_KEY="ANAHTAR_1,ANAHTAR_2,ANAHTAR_3,ANAHTAR_4,ANAHTAR_5"
VITE_GEMINI_MODEL="gemini-2.0-flash"

# --- FIREBASE ---
# Firebase Console'dan alınır: https://console.firebase.google.com
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxx"

# --- GOOGLE CUSTOM SEARCH API (Sentinel Ajanı) ---
# Programmable Search Engine: https://programmablesearchengine.google.com
# API Key: https://console.cloud.google.com/apis/credentials
# Ücretsiz tier: Günlük 100 sorgu
VITE_GOOGLE_SEARCH_API_KEY="YOUR_GOOGLE_SEARCH_API_KEY"
VITE_GOOGLE_SEARCH_ENGINE_ID="YOUR_SEARCH_ENGINE_ID"
