rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Kullanıcılar Koleksiyonu
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Projeler Koleksiyonu (GİZLİLİK GÜNCELLEMESİ)
    match /projects/{projectId} {
      // Sadece sahibi içeriği okuyabilir, ADMİNLER OKUYAMAZ (Privacy)
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Anonim Feedback Koleksiyonu (ADMİN PANELİ İÇİN)
    match /feedback_summaries/{feedbackId} {
      allow read: if isAdmin(); // Adminler buradan analiz sonuçlarını görür
      allow create: if request.auth != null; // Her kullanıcı geri bildirim bırakabilir
    }

    // Diğer kurallar aynen korunur...
    match /customTones/{toneId} {
      allow read, update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
    // Sentinel Logları (Admin panelinden okunur)
    match /sentinelLogs/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
