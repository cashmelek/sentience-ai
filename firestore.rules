rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin kontrolü: users koleksiyonunda role == 'admin' olan kullanıcılar
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Kullanıcılar Koleksiyonu
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Projeler Koleksiyonu
    match /projects/{projectId} {
      allow read, update, delete: if request.auth != null && 
                                    (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid;
    }

    // Özel Tonlar Koleksiyonu
    match /customTones/{toneId} {
      allow read, update, delete: if request.auth != null && 
                                    (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid;
    }

    // Sistem Ayarları Koleksiyonu - herkes okuyabilir (bakım modu için), sadece admin yazabilir
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Aktivite Logları Koleksiyonu - sadece admin okuyabilir ve yazabilir
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
